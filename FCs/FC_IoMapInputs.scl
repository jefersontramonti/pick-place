FUNCTION "FC_IoMapInputs" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1

// Pick & Place — Copyright (C) 2026 Jeferson Tramonti
// Licenciado sob a GNU GPLv3 — veja o arquivo LICENSE.

// Mapeamento de ENTRADAS físicas (%I/%ID) -> StationData.Station.
// FC stateless, chamada no INICIO do scan pelo OB_Main. Isola TODO o endereçamento
// físico de entrada num ponto único (princípio §6 da arquitetura).
//
// Comandos Start/Stop/Reset agora são MESCLA físico + IHM (bits Cmd.Hmi*):
//   - Start := físico OR HmiStart      (NA — OR é seguro)
//   - Reset := físico OR HmiReset      (NA — OR é seguro; borda no FB_MachineMode)
//   - Stop  := físico AND NOT HmiStopReq (Stop é NF: a IHM só ADICIONA parada, nunca destrava)
// EStop permanece EXCLUSIVAMENTE físico — a IHM NÃO comanda emergência (segurança).
//
// Safety: os sinais de emergência (EStop %I0.3, Stop %I0.7) chegam CRUS do campo —
// sem inversão, sem máscara. A interpretação NF (FALSE = acionado, latch, fail-safe)
// é EXCLUSIVA do FB_MachineMode. (a) Stop é NF: a IHM (AND NOT) só pode ADICIONAR
// parada, nunca "destravar" — fio físico rompido (i_Stop=FALSE) continua parando
// independente da IHM. (b) EStop não é tocado: a parada de emergência segura segue
// só física. (c) Botões HMI são momentâneos (WinCC "set bit while key pressed"):
// Start/Reset usam R_TRIG no FB_MachineMode (1 pulso = 1 borda); um HmiStopReq
// momentâneo leva o FSM a PARADO (latcheado até novo Start).

    VAR_INPUT
        i_EStop : Bool;   // %I0.3 — cru (NF, NÃO inverter)
        i_Stop : Bool;   // %I0.7 — cru (NF, NÃO inverter)
        i_Start : Bool;   // %I0.6 — cru (NA)
        i_Reset : Bool;   // %I0.4 — cru (NA, pulso; borda fica no FB_MachineMode)
        i_SensorBox : Bool;   // %I0.5 — sensor da caixa na M1 (NA)
        i_Rotating : Bool;   // %I1.0 — feedback de rotação
        i_RotHome : Bool;   // %I1.3 — HOME de rotacao (braco na casa, virado p/ M1)
        i_ItemDetected : Bool;   // %I1.1 — caixa na ventosa
        i_Xpos : Real;   // %ID30 — posição X (V)
        i_Zpos : Real;   // %ID34 — posição Z (V)
    END_VAR

    VAR_IN_OUT
        io_Station : "typeStation";   // referência ao StationData.Station
    END_VAR

BEGIN

    REGION Comandos
    // Start/Stop/Reset = MESCLA físico + IHM; EStop = físico exclusivo (NF não invertido).
    // REARME — DOIS CAMINHOS SEPARADOS (decisão de segurança, co-localização):
    //   - Cmd.Reset (MESCLADO físico OR IHM) -> clear de FALHA funcional (FB_PickPlaceSeq).
    //     A IHM PODE resetar falha remotamente.
    //   - Cmd.ResetPhys (FISICO CRU, %I0.4) -> clear de EMERGENCIA (FB_MachineMode).
    //     A IHM NAO destrava emergência: o rearme exige presença física co-localizada
    //     (operador no painel), além do E-Stop já rearmado.
        #io_Station.Cmd.EStop := #i_EStop;                                   // SEGURANCA: fisico so (NF, nao inverter) — IHM nao comanda
        #io_Station.Cmd.Stop := #i_Stop AND NOT #io_Station.Cmd.HmiStopReq; // NF (TRUE=ok): IHM forca parada funcional levando a FALSE
        #io_Station.Cmd.Start := #i_Start OR #io_Station.Cmd.HmiStart;       // NA: liga por botao fisico OU IHM
        #io_Station.Cmd.Reset := #i_Reset OR #io_Station.Cmd.HmiReset;       // NA: reset MESCLADO p/ FALHA (fisico OU IHM; borda no consumidor)
        #io_Station.Cmd.ResetPhys := #i_Reset;                               // reset fisico cru (so p/ clear de EMERGENCIA no FB_MachineMode)
    END_REGION

    REGION Feedbacks
    // Espelhos dos sensores de feedback no StationData.Sts
        #io_Station.Sts.Rotating := #i_Rotating;
        #io_Station.Sts.RotHome := #i_RotHome;
        #io_Station.Sts.ItemDetected := #i_ItemDetected;
        #io_Station.Sts.SensorBox := #i_SensorBox;
    END_REGION

    REGION Posicoes dos eixos
    // Real (%ID, 32-bit) -> LReal (ampliação segura)
        #io_Station.Sts.AxisX.PV := #i_Xpos;
        #io_Station.Sts.AxisZ.PV := #i_Zpos;
    END_REGION

END_FUNCTION
