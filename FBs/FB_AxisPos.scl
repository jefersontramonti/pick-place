FUNCTION_BLOCK "FB_AxisPos"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1

// FB_AxisPos: primitiva genérica de posicionamento de UM eixo analógico (interface ESCALAR).
// Comanda o setpoint (o_SetPointCmd -> %QD), lê o feedback (i_PV <- %ID) e gera "em posição"
// (o_InPos) por tolerância + debounce. Em ESTADO SEGURO congela na POSIÇÃO ATUAL (SP := PV,
// segura onde está — não percorre ao destino); desabilitado, mantém o último destino.
// Instanciada por eixo (X, Z) dentro do FB_PickPlaceSeq (multi-instância);
// NÃO chamar de OB diretamente. Fonte: ARQUITETURA_PickPlace.md §2.7.
    VAR_INPUT
        i_Enable : Bool;    // FALSE = congela (não comanda novo SP)
        i_SafeState : Bool;    // TRUE = congela (estado seguro: não comanda novo destino)
        i_SetPoint : LReal;   // SP desejado (V)
        i_PV : LReal;   // feedback de posição (V)
        i_Tol : LReal;   // tolerância "em posição" (V) — vem de Cfg.PosTol
        i_Debounce : Time;    // estabilização do "em posição" — vem de Cfg.PosDebounce
    END_VAR

    VAR_OUTPUT
        o_SetPointCmd : LReal := 0.0;   // SP a escrever no %QD (mantém valor em freeze; 0 V = seguro na energização)
        o_InPos : Bool;    // TRUE quando |SPcmd - PV| <= Tol estável por Debounce
    END_VAR

    VAR
        s_tDebounce : TON_TIME;  // debounce do "em posição"
    END_VAR

BEGIN

    REGION Comando de setpoint
    // Estado seguro (i_SafeState): congela na POSICAO ATUAL (o_SetPointCmd := i_PV) — o eixo
    // SEGURA ONDE ESTA, nao percorre ate o ultimo destino comandado. Este e o "estado seguro"
    // real do eixo: evita que ele continue se movendo durante falha/E-Stop (achado A-1 — foi
    // o que fez o robo descer na caixa). Habilitado e fora de safe: comanda o destino.
    // Desabilitado e fora de safe: mantem o ultimo destino (VAR_OUTPUT persiste no DB).
        IF #i_SafeState THEN
            #o_SetPointCmd := #i_PV;
        ELSIF #i_Enable THEN
            #o_SetPointCmd := #i_SetPoint;
        END_IF;
    END_REGION

    REGION Em posicao
    // "em posição" = |SP comandado - PV| <= tolerância, estável por Debounce.
    // Usa o_SetPointCmd (o destino atual, mesmo congelado), não i_SetPoint.
        #s_tDebounce(IN := ABS(#o_SetPointCmd - #i_PV) <= #i_Tol,
        PT := #i_Debounce);
        #o_InPos := #s_tDebounce.Q;
    END_REGION

END_FUNCTION_BLOCK